---
import { SITE } from '../config/site';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!-- Accent bar primary di paling atas card -->
<div class="h-1 bg-primary w-full rounded-t-xl"></div>

<!-- Konten header di dalam card -->
<div class="px-6 pt-6 pb-4">
  <div class="flex items-center gap-4 justify-center">
    <!-- Logo Container -->
    <div class="shrink-0">
      <div class="w-14 h-14 flex items-center justify-center">
        <Image
          src={logoImage}
          alt={SITE.company}
          class="w-full h-full object-contain"
          loading="eager"
        />
      </div>
    </div>

    <!-- Title & Company Container -->
    <div class="flex flex-col">
      <h3 class="text-[18px] font-semibold tracking-tight leading-none mb-1">
        {title}
      </h3>
      <p class="text-[11px] font-medium text-primary tracking-wider">
        {SITE.company}
      </p>
    </div>
  </div>

  
</div>


