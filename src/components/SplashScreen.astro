---
import { SITE } from '../config/site';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';

interface Props {
  revealId: string;
  duration?: number;
}

const { revealId, duration = 2000 } = Astro.props;
---

<!-- SPLASH SCREEN -->
<div 
  id="splash" 
  aria-hidden="true" 
  data-reveal={revealId} 
  data-duration={duration}
  class="fixed inset-0 z-[9999] bg-white flex flex-col items-center justify-center gap-4 animate-splash-fade-in"
>
  <Image 
    src={logoImage} 
    alt={SITE.company} 
    class="h-[150px] object-contain animate-splash-up delay-100" 
  />
</div>

<script>
  const splash   = document.getElementById('splash')!;
  const revealId = splash.dataset.reveal!;
  const duration = Number(splash.dataset.duration ?? 2000);
  const target   = document.getElementById(revealId)!;

  setTimeout(() => {
    splash.classList.add('animate-splash-out');
    setTimeout(() => {
      splash.style.display = 'none';
      target.classList.replace('opacity-0', 'opacity-100');
    }, 350);
  }, duration);
</script>
