---
/**
 * Halaman formulir buku tamu.
 * Diakses user setelah scan QR Code dengan URL: /visit/<token>
 *
 * Alur:
 * 1. Token diambil dari URL params
 * 2. Validasi token ke backend API
 * 3. Splash screen tampil 2 detik, lalu form muncul
 * 4. User mengisi form dan submit ke POST /api/guest
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SplashScreen from '../../components/SplashScreen.astro';
import PageHeader from '../../components/PageHeader.astro';
import GuestForm from '../../components/GuestForm.svelte';
import { SITE } from '../../config/site';

const { token } = Astro.params;

const standby_security = Astro.url.searchParams.get('standby_security') || undefined;
const visiting_office = Astro.url.searchParams.get('visiting_office') || undefined;

// Redirect jika token tidak ada di URL
if (!token) {
  return Astro.redirect('/invalid?reason=invalid');
}

// Validasi token ke backend
const API_BASE = import.meta.env.PUBLIC_API_BASE_URL;
const validationUrl = `${API_BASE}/public/guestbook?validate=token`;

try {
  // Kirim token ke server untuk validasi
  const res = await fetch(validationUrl, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({ token }),
  });

  if (res.ok) {
    const data = await res.json();

    // Cek properti 'valid' dari respon backend
    if (!data.valid) {
      console.error(`Token invalid! URL: ${token}, Response:`, data);
      return Astro.redirect(`/invalid?reason=invalid`);
    }
  } else {
    // Jika server kirim error (misal 500 atau 404)
    console.error(`Server error during token validation. Status: ${res.status}`);
    return Astro.redirect(`/invalid?reason=invalid`);
  }
} catch (error) {
  console.error(`Network error validating token ${token} at ${validationUrl}:`, error);
  // Di sini kita redirect jika gagal koneksi agar security terjamin
  return Astro.redirect('/invalid?reason=invalid');
}
---

<BaseLayout
  title={SITE.appName}
  description={`Formulir buku tamu digital ${SITE.company}. Isi data kunjungan Anda.`}
  bodyClass='min-h-screen bg-[#f8fafc]'
>
  <meta
    slot='head'
    id='app-config'
    data-tz={SITE.timezone}
    data-tz-label={SITE.timezoneLabel}
    data-locale={SITE.locale}
  />
  <SplashScreen revealId='main-content' />

  <div id='main-content' class='opacity-0 transition-opacity duration-400 ease-out pt-6 px-4 pb-24'>
    <main class='w-full max-w-[480px] mx-auto'>
      <div class='bg-white rounded-2xl border border-slate-200 overflow-hidden'>
        <PageHeader title={SITE.appName} />
        <GuestForm client:load {token} {standby_security} {visiting_office} />
      </div>
      <p class='text-xs text-center text-slate-400 mt-5'>
        Data Anda tersimpan dengan aman dan hanya digunakan untuk keperluan kunjungan.
      </p>
    </main>
    <p
      class='text-[10px] text-center text-slate-400 mt-8 mb-4 uppercase tracking-widest font-medium'
    >
      &copy; {new Date().getFullYear()}
      {SITE.copyright}
    </p>
  </div>
</BaseLayout>
