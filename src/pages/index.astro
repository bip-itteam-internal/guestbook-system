---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title={SITE.appName}
  description={`Sistem Buku Tamu Digital berbasis QR Code untuk keperluan kunjungan ${SITE.company}.`}
  bodyClass="min-h-screen bg-[#f8fafc]"
>
  <style slot="head">
    #splash {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      animation: splash-fade-in 0.4s ease both;
    }
    @keyframes splash-fade-in {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    .splash-logo {
      height: 68px;
      object-fit: contain;
      animation: splash-up 0.5s ease 0.1s both;
    }
    .splash-divider {
      width: 32px;
      height: 2px;
      background: var(--color-primary);
      border-radius: 99px;
      animation: splash-up 0.5s ease 0.2s both;
    }
    .splash-welcome {
      font-size: 13px;
      font-weight: 500;
      color: #94a3b8;
      letter-spacing: 0.3px;
      animation: splash-up 0.5s ease 0.25s both;
    }
    .splash-name {
      font-size: 15px;
      font-weight: 700;
      color: #0f172a;
      text-align: center;
      line-height: 1.5;
      max-width: 220px;
      animation: splash-up 0.5s ease 0.35s both;
    }
    @keyframes splash-up {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    #splash.exit {
      animation: splash-out 0.35s ease forwards;
    }
    @keyframes splash-out {
      from { opacity: 1; }
      to   { opacity: 0; }
    }
    #main-content {
      opacity: 0;
      transition: opacity 0.4s ease;
    }
    #main-content.visible {
      opacity: 1;
    }
  </style>

  <!-- SPLASH -->
  <div id="splash" aria-hidden="true">
    <img src={SITE.logo} alt={SITE.company} class="splash-logo" />
    <div class="splash-divider"></div>
    <p class="splash-welcome">Selamat Datang di</p>
    <p class="splash-name">{SITE.company}</p>
  </div>

  <!-- MAIN CONTENT -->
  <div id="main-content" class="flex items-center justify-center min-h-screen px-4 py-12">
    <main class="w-full max-w-[440px]">

      <!-- Header -->
      <div class="text-center mb-8">
        <img src={SITE.logo} alt={SITE.company} class="h-14 mx-auto object-contain mb-5" />
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">{SITE.appName}</h1>
        <p class="text-sm text-slate-500 mt-1 font-medium">{SITE.company}</p>
        <p class="text-sm text-slate-400 mt-3 leading-relaxed">
          Sistem pencatatan tamu berbasis QR Code.<br />
          Scan QR Code untuk mengisi buku tamu.
        </p>
      </div>

      <!-- Card -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <!-- Top accent -->
        <div class="h-1 bg-primary w-full"></div>

        <div class="p-6">
          <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Cara Penggunaan</h2>
          <ol class="space-y-4">
            <li class="flex gap-4 items-start">
              <span class="w-7 h-7 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
              <div>
                <p class="text-sm font-medium text-slate-700">Scan QR Code</p>
                <p class="text-xs text-slate-400 mt-0.5">Tersedia di petugas security</p>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="w-7 h-7 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
              <div>
                <p class="text-sm font-medium text-slate-700">Isi Formulir</p>
                <p class="text-xs text-slate-400 mt-0.5">Lengkapi data kunjungan dengan benar</p>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="w-7 h-7 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
              <div>
                <p class="text-sm font-medium text-slate-700">Kirim Data</p>
                <p class="text-xs text-slate-400 mt-0.5">Tekan tombol <strong class="text-slate-600">Kirim Data</strong> untuk menyimpan</p>
              </div>
            </li>
          </ol>
        </div>
      </div>

      <p class="text-xs text-center text-slate-400 mt-6">
        &copy; {new Date().getFullYear()} {SITE.company}
      </p>
    </main>
  </div>
</BaseLayout>

<script>
  const splash = document.getElementById('splash')!;
  const main   = document.getElementById('main-content')!;

  setTimeout(() => {
    splash.classList.add('exit');
    setTimeout(() => {
      splash.style.display = 'none';
      main.classList.add('visible');
    }, 350);
  }, 2000);
</script>
