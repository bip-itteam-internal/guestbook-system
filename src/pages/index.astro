---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title={SITE.appName}
  description={`Sistem Buku Tamu Digital berbasis QR Code untuk keperluan kunjungan ${SITE.company}.`}
  bodyClass="min-h-screen bg-gray-50"
>
  <!-- Splash Screen styles -->
  <style slot="head">
    /* ─── Splash Screen ─────────────────────────────────────── */
    #splash {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #0f172a;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    #splash::before {
      content: '';
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,158,65,0.25) 0%, transparent 70%);
      animation: glow-pulse 3s ease-in-out infinite;
    }
    @keyframes glow-pulse {
      0%, 100% { transform: scale(0.9); opacity: 0.6; }
      50%       { transform: scale(1.2); opacity: 1; }
    }
    .splash-ring {
      position: absolute;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      border: 1.5px solid rgba(0,158,65,0.35);
      animation: ring-spin 8s linear infinite;
    }
    .splash-ring:nth-child(2) {
      width: 200px;
      height: 200px;
      border-color: rgba(30,41,59,0.8);
      animation-direction: reverse;
      animation-duration: 12s;
    }
    .splash-ring::after {
      content: '';
      position: absolute;
      top: -3px;
      left: 50%;
      transform: translateX(-50%);
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-primary);
    }
    @keyframes ring-spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    .splash-logo-wrap {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
    .splash-logo-box {
      width: 100px;
      height: 100px;
      background: white;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 40px rgba(0,158,65,0.3), 0 20px 60px rgba(0,0,0,0.4);
      animation: logo-enter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }
    @keyframes logo-enter {
      from { opacity: 0; transform: scale(0.4) rotate(-10deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }
    .splash-company {
      margin-top: 28px;
      text-align: center;
      animation: text-rise 0.7s ease-out 1.1s both;
    }
    .splash-brand {
      font-size: 22px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: 3px;
      text-transform: uppercase;
    }
    .splash-sub {
      font-size: 11px;
      color: var(--color-primary);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-top: 4px;
      font-weight: 500;
    }
    @keyframes text-rise {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .splash-tagline {
      margin-top: 12px;
      font-size: 11px;
      color: rgba(255,255,255,0.35);
      letter-spacing: 1px;
      animation: text-rise 0.7s ease-out 1.5s both;
    }
    .splash-loader {
      margin-top: 48px;
      width: 160px;
      height: 2px;
      background: rgba(255,255,255,0.08);
      border-radius: 99px;
      overflow: hidden;
      animation: text-rise 0.5s ease-out 1.8s both;
      position: relative;
      z-index: 2;
    }
    .splash-loader-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--color-primary), color-mix(in srgb, var(--color-primary) 75%, white), var(--color-primary));
      background-size: 200% 100%;
      border-radius: 99px;
      animation: loader-fill 1.5s ease-out 2s forwards, shimmer 1.5s linear 2s infinite;
    }
    @keyframes loader-fill {
      from { width: 0%; }
      to   { width: 100%; }
    }
    @keyframes shimmer {
      from { background-position: 200% 0; }
      to   { background-position: -200% 0; }
    }
    .particle {
      position: absolute;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(0,158,65,0.6);
      animation: float-up linear infinite;
    }
    @keyframes float-up {
      0%   { transform: translateY(0) scale(1); opacity: 0.7; }
      100% { transform: translateY(-100vh) scale(0); opacity: 0; }
    }
    #splash.exit {
      animation: splash-exit 0.9s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    @keyframes splash-exit {
      0%   { opacity: 1; transform: translateY(0); clip-path: inset(0 0 0 0); }
      100% { opacity: 0; transform: translateY(-30px); clip-path: inset(0 0 100% 0); }
    }
    #main-content {
      opacity: 0;
      transition: opacity 0.5s ease;
    }
    #main-content.visible {
      opacity: 1;
    }
  </style>

  <!-- ─── SPLASH SCREEN ─────────────────────────────────────── -->
  <div id="splash" aria-hidden="true">
    <!-- Particles -->
    <div class="particle" style="left:10%;animation-duration:6s;animation-delay:0.5s;"></div>
    <div class="particle" style="left:25%;animation-duration:8s;animation-delay:1.2s;width:3px;height:3px;"></div>
    <div class="particle" style="left:60%;animation-duration:5s;animation-delay:0.8s;"></div>
    <div class="particle" style="left:75%;animation-duration:9s;animation-delay:2s;width:2px;height:2px;"></div>
    <div class="particle" style="left:88%;animation-duration:7s;animation-delay:0.3s;"></div>
    <div class="particle" style="left:42%;animation-duration:6.5s;animation-delay:1.8s;width:3px;height:3px;"></div>

    <!-- Rotating rings -->
    <div class="splash-ring"></div>
    <div class="splash-ring"></div>

    <!-- Logo + Text -->
    <div class="splash-logo-wrap">
      <div class="splash-logo-box">
        <img src={SITE.logo} alt={`Logo ${SITE.company}`} style="height:72px;object-fit:contain;" />
      </div>
      <div class="splash-company">
        <p class="splash-brand">{SITE.companyShort}</p>
        <p class="splash-sub">{SITE.companyShort2}</p>
      </div>
      <p class="splash-tagline">{SITE.tagline}</p>
    </div>

    <!-- Loading bar -->
    <div class="splash-loader">
      <div class="splash-loader-fill"></div>
    </div>
  </div>

  <!-- ─── MAIN CONTENT ───────────────────────────────────────── -->
  <div id="main-content" class="flex items-center justify-center min-h-screen px-4 py-10">
    <main class="w-full max-w-[480px] text-center">

      <!-- Logo / Header -->
      <div class="mb-8">
        <div class="mx-auto mb-5">
          <img src={SITE.logo} alt={SITE.company} class="h-16 mx-auto object-contain" />
        </div>
        <h1 class="text-2xl font-bold text-slate-800">{SITE.appName}</h1>
        <p class="text-sm font-semibold text-slate-600 mt-1">{SITE.company}</p>
        <p class="text-gray-500 mt-2 text-sm leading-relaxed">
          Sistem pencatatan tamu berbasis QR Code.<br />
          Silakan scan QR Code yang tersedia untuk mengisi buku tamu.
        </p>
      </div>

      <!-- Info Card -->
      <div class="bg-white border border-gray-200 rounded-2xl p-6 text-left shadow-sm">
        <h2 class="font-semibold text-slate-700 mb-3 text-sm uppercase tracking-wide">Cara Penggunaan</h2>
        <ol class="space-y-3 text-sm text-gray-600">
          <li class="flex gap-3 items-start">
            <span class="w-6 h-6 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
            <span>Scan QR Code yang tersedia di petugas security</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="w-6 h-6 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
            <span>Isi formulir data kunjungan dengan lengkap</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="w-6 h-6 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
            <span>Tekan tombol <strong>Kirim Data</strong> untuk menyimpan</span>
          </li>
        </ol>
      </div>

      <p class="text-xs text-gray-400 mt-6">
        &copy; {new Date().getFullYear()} {SITE.company}
      </p>
    </main>
  </div>
</BaseLayout>

<script>
  const splash = document.getElementById('splash')!;
  const main   = document.getElementById('main-content')!;

  setTimeout(() => {
    splash.classList.add('exit');
    setTimeout(() => {
      splash.style.display = 'none';
      main.classList.add('visible');
    }, 900);
  }, 3600);
</script>
