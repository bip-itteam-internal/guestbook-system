---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';
---

<BaseLayout
  title={SITE.appName}
  description={`Sistem Buku Tamu Digital berbasis QR Code untuk keperluan kunjungan ${SITE.company}.`}
  bodyClass="min-h-screen bg-[#f8fafc] flex items-center justify-center px-4 py-12"
>
  <main class="w-full max-w-[440px]">

    <!-- Header -->
    <div class="text-center mb-8">
      <Image src={logoImage} alt={SITE.company} class="h-24 mx-auto object-contain mb-5" />
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">{SITE.appName}</h1>
      <p class="text-sm text-slate-500 mt-1 font-medium">{SITE.company}</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <!-- Top accent -->
      <div class="h-1 bg-primary w-full"></div>

      <div class="p-6">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Cara Penggunaan</h2>
        <ol class="space-y-4">
          <li class="flex gap-4 items-start">
            <span class="w-7 h-7 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
            <div>
              <p class="text-sm font-medium text-slate-700">Scan QR Code</p>
              <p class="text-xs text-slate-400 mt-0.5">Tersedia di petugas security</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <span class="w-7 h-7 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
            <div>
              <p class="text-sm font-medium text-slate-700">Isi Formulir</p>
              <p class="text-xs text-slate-400 mt-0.5">Lengkapi data kunjungan dengan benar</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <span class="w-7 h-7 rounded-full bg-primary-light text-primary font-bold text-xs flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
            <div>
              <p class="text-sm font-medium text-slate-700">Kirim Data</p>
              <p class="text-xs text-slate-400 mt-0.5">Tekan tombol <strong class="text-slate-600">Kirim Data</strong> untuk menyimpan</p>
            </div>
          </li>
        </ol>
      </div>
    </div>

    <p class="text-xs text-center text-slate-400 mt-6">
      &copy; {new Date().getFullYear()} {SITE.company}
    </p>
  </main>
</BaseLayout>
